APP_NAME="نظام إدارة طلبات العملاء"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://crm.moathhamad.space
APP_LOCALE=ar
APP_TIMEZONE=Asia/Riyadh

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=crm_system
DB_USERNAME=crm_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=public

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://crm.moathhamad.space/auth/google/callback

# Internal staff email domain
STAFF_EMAIL_DOMAIN=altqniah.sa

# Cron/API secrets
CRON_SECRET=CHANGE_ME_RANDOM
